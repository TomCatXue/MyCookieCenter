# ============================================
# 微信读书 · 会员解锁
# 导入方法: Loon > 配置 > 插件 > 导入此文件
# ============================================

[MITM]
hostname = i.weread.qq.com, *.unipay.qq.com

[Script]
http-response ^https://i\.weread\.qq\.com\/pay\/(memberCardSummary|memberCardItems|memberCardDetails|membercardexitems|membercardsummary|careplan|item) script-path=weread_vip.js, tag=微信读书会员
http-response ^https://api\.unipay\.qq\.com\/v1\/r\/ script-path=weread_vip.js, tag=微信读书支付
