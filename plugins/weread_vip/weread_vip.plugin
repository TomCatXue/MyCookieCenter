#!name = 微信读书VIP解锁
#!desc = 会员解锁 + 充值币 + OnePatch验证绕过
#!author = TomCatXue
#!homepage = https://github.com/TomCatXue/MyCookieCenter
#!icon = https://raw.githubusercontent.com/TomCatXue/MyCookieCenter/refs/heads/main/icons/weread.png
#!tag = 微信读书,会员解锁,VIP

# ===== MITM =====

[MITM]
hostname = i.weread.qq.com, weread.qq.com, api.unipay.qq.com

# ===== 脚本规则 =====

[Script]
# VIP会员 + 充值币 + 支付回调
http-response ^https://i\.weread\.qq\.com/(login|pay/|user/) tag=VIP解锁, script-path=https://raw.githubusercontent.com/TomCatXue/MyCookieCenter/refs/heads/main/plugins/weread_vip/weread_vip.js, requires-body=true, enable=true
http-response ^https://api\.unipay\.qq\.com/v1/r/ tag=Midas支付, script-path=https://raw.githubusercontent.com/TomCatXue/MyCookieCenter/refs/heads/main/plugins/weread_vip/weread_vip.js, requires-body=true, enable=true

# OnePatch原生验证绕过
http-response ^https://weread\.qq\.com/(wrpage|web|misc-next|policy|book-detail|invitation-gift) tag=验证绕过, script-path=https://raw.githubusercontent.com/TomCatXue/MyCookieCenter/refs/heads/main/plugins/weread_vip/weread_patch.js, requires-body=true, enable=true

# 书架收录
http-request ^https://i\.weread\.qq\.com/subscription/users tag=书架收录, script-path=https://raw.githubusercontent.com/TomCatXue/MyCookieCenter/refs/heads/main/plugins/wxread/wxread.js, enable=true
