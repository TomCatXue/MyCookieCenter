#!name = QQ空间广告屏蔽
#!desc = 屏蔽QQ空间广告，规则来自 zqzess/rule_for_quantumultX，已整合至本项目仓库。
#!author = zqzess / TomCatXue
#!homepage = https://github.com/TomCatXue/MyCookieCenter
#!icon = https://raw.githubusercontent.com/TomCatXue/MyCookieCenter/refs/heads/main/icons/icon.png
#!tag = 广告屏蔽,QQ空间

# 独立开关
[Argument]
qzone_ad_block = switch,false,tag=QQ空间,desc=屏蔽QQ空间广告（规则型，无需MITM）

# 域名规则 — 直接 REJECT
[Rule]
DOMAIN,d3g.qq.com,REJECT,enable={qzone_ad_block}
DOMAIN,bsrv.qq.com,REJECT,enable={qzone_ad_block}
DOMAIN,sq.bls.mdt.qq.com,REJECT,enable={qzone_ad_block}
DOMAIN,adsmind.gdtimg.com,REJECT,enable={qzone_ad_block}
DOMAIN,xj-landing.gdtimg.com,REJECT,enable={qzone_ad_block}

# URL 重写 — 将广告请求 redirect 到 reject
[URL Rewrite]
^http://c\.gdt\.qq\.com/gdt_clickwap\.fcg\?viewid _ reject,enable={qzone_ad_block}
^http://pgdt\.gtimg\.cn/gdt/0/.*\.jpg _ reject,enable={qzone_ad_block}
^http://v\.gdt\.qq\.com/gdt_stats\.fcg\?viewid _ reject,enable={qzone_ad_block}
^http://rpt\.gdt\.qq\.com/creative_view\?viewid _ reject,enable={qzone_ad_block}
^http://pgdt\.gtimg\.cn/gdt/.*\.png _ reject,enable={qzone_ad_block}
^http://pgdt\.gtimg\.cn/gdt/.*\.jpg _ reject,enable={qzone_ad_block}
^http://pgdt\.gtimg\.cn/.*/snscosdownload/SH/reserved/.* _ reject,enable={qzone_ad_block}
